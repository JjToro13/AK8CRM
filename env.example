# Configuración de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key

# Configuración de Did-glo-bal (para Edge Functions - credenciales globales de fallback)
# Token de acceso de Did-glo-bal
DID_GLO_BAL_ACCESS_TOKEN=tu_access_token
# URL del webhook para recibir eventos de llamadas
DID_GLO_BAL_WEBHOOK_URL=https://tu-proyecto.supabase.co/functions/v1
# URL base de la API de Did-glo-bal
DID_GLO_BAL_API_URL=https://b.didpbx.com
# URL específica para llamadas
DID_GLO_BAL_CALLS_URL=https://b.didpbx.com/amocrm/TU_EXTENSION_ID/TU_ACCESS_TOKEN
# URL para webhooks comunes
DID_GLO_BAL_COMMON_URL=https://b.didpbx.com/commoncrm/TU_EXTENSION_ID

# Configuración de Supabase (para Edge Functions)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Configuración de Seguridad
# Contraseña para crear cuentas de administrador
VITE_ADMIN_CREATION_PASSWORD=tu_password_segura

# Configuración de Email
VITE_COMPANY_EMAIL=noreply@tuempresa.com
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=tu_email@gmail.com
VITE_SMTP_PASS=tu_app_password

# Configuración de Encriptación
# Clave para encriptar tokens de Did-glo-bal (mínimo 32 caracteres)
VITE_ENCRYPTION_KEY=tu_clave_secreta_minimo_32_caracteres_muy_segura
